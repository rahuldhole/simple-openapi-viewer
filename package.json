{
  "name": "simple-openapi-viewer",
  "displayName": "Simple OpenAPI Viewer",
  "description": "Preview OpenAPI YAML and JSON files in a lightweight VS Code webview.",
  "version": "0.0.1",
  "publisher": "RahulDhole",
  "license": "MIT",
  "icon": "resources/icon.png",
  "keywords": [
    "openapi",
    "swagger",
    "api",
    "viewer",
    "documentation",
    "yaml",
    "json",
    "rest"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuldhole/simple-openapi-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/rahuldhole/simple-openapi-viewer/issues"
  },
  "homepage": "https://github.com/rahuldhole/simple-openapi-viewer#readme",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "onLanguage:yml",
    "onLanguage:json",
    "onCommand:simple-openapi-viewer.openViewer",
    "onCommand:simple-openapi-viewer.openViewerFromExplorer"
  ],
  "packageManager": "pnpm@9.0.0",
  "main": "./src/extension.js",
  "scripts": {
    "dev": "pnpm install && echo 'Development environment ready. Press F5 in VS Code to start debugging.'",
    "test": "node --test ./src/test/extension.test.js",
    "package": "rm -rf *.vsix && pnpx vsce package --no-dependencies",
    "publish": "pnpx vsce publish",
    "lint": "eslint ."
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "swagger-ui-dist": "^5.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.8.1",
    "eslint": "^10.2.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "simple-openapi-viewer.openViewer",
        "title": "Open Current File",
        "category": "OpenAPI Viewer",
        "icon": {
          "light": "resources/icon.svg",
          "dark": "resources/icon-dark.svg"
        }
      },
      {
        "command": "simple-openapi-viewer.openViewerFromExplorer",
        "title": "Open File in Viewer",
        "category": "OpenAPI Viewer"
      }
    ],
    "customEditors": [
      {
        "viewType": "simple-openapi-viewer.openViewer",
        "displayName": "OpenAPI Viewer",
        "selector": [
          {
            "filenamePattern": "*.{json,yaml,yml}"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "simple-openapi-viewer.openViewer"
        }
      ],
      "explorer/context": [
        {
          "command": "simple-openapi-viewer.openViewerFromExplorer",
          "when": "resourceLangId == 'yaml' || resourceLangId == 'json' || resourceExtname == '.yaml' || resourceExtname == '.yml' || resourceExtname == '.json'",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "simple-openapi-viewer.openViewer",
          "when": "(resourceLangId == 'yaml' || resourceLangId == 'json' || resourceExtname == '.yaml' || resourceExtname == '.yml' || resourceExtname == '.json') && simple-openapi-viewer.isOpenApi",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "simple-openapi-viewer.openViewer",
          "when": "(resourceLangId == 'yaml' || resourceLangId == 'json' || resourceExtname == '.yaml' || resourceExtname == '.yml' || resourceExtname == '.json') && simple-openapi-viewer.isOpenApi",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "simple-openapi-viewer.openViewer",
        "key": "cmd+alt+o",
        "mac": "cmd+alt+o",
        "when": "editorTextFocus"
      }
    ]
  }
}
