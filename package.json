{
  "name": "simple-openapi-viewer",
  "displayName": "Simple OpenAPI Viewer",
  "description": "Preview OpenAPI YAML and JSON files in a lightweight VS Code webview.",
  "version": "0.0.1",
  "publisher": "RahulDhole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahuldhole/simple-openapi-viewer.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:yaml",
    "onLanguage:yml",
    "onLanguage:json",
    "onCommand:simple-openapi-viewer.openViewer",
    "onCommand:simple-openapi-viewer.openViewerFromExplorer"
  ],
  "packageManager": "pnpm@9.0.0",
  "main": "./src/extension.js",
  "scripts": {
    "dev": "pnpm install && echo 'Development environment ready. Press F5 in VS Code to start debugging.'",
    "test": "node --test ./src/test/extension.test.js",
    "package": "pnpx vsce package --no-dependencies",
    "publish": "pnpx vsce publish",
    "lint": "eslint ."
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "swagger-ui-dist": "^5.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "typescript": "^5.5.0",
    "vsce": "^2.0.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "simple-openapi-viewer.openViewer",
        "title": "Open Current File",
        "category": "OpenAPI Viewer",
        "icon": {
          "light": "resources/swagger.svg",
          "dark": "resources/swagger.svg"
        }
      },
      {
        "command": "simple-openapi-viewer.openViewerFromExplorer",
        "title": "Open File in Viewer",
        "category": "OpenAPI Viewer"
      }
    ],
    "customEditors": [
      {
        "viewType": "simple-openapi-viewer.openViewer",
        "displayName": "OpenAPI Viewer",
        "selector": [
          {
            "filenamePattern": "*.{json,yaml,yml}"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "simple-openapi-viewer.openViewer"
        }
      ],
      "explorer/context": [
        {
          "command": "simple-openapi-viewer.openViewerFromExplorer",
          "when": "resourceLangId == 'yaml' || resourceLangId == 'json' || resourceExtname == '.yaml' || resourceExtname == '.yml' || resourceExtname == '.json'",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "simple-openapi-viewer.openViewer",
          "when": "resourceLangId == 'yaml' || resourceLangId == 'json' || resourceExtname == '.yaml' || resourceExtname == '.yml' || resourceExtname == '.json'",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "simple-openapi-viewer.openViewer",
          "when": "resourceLangId == 'yaml' || resourceLangId == 'json' || resourceExtname == '.yaml' || resourceExtname == '.yml' || resourceExtname == '.json'",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "simple-openapi-viewer.openViewer",
        "key": "cmd+alt+o",
        "mac": "cmd+alt+o",
        "when": "editorTextFocus"
      }
    ]
  }
}
